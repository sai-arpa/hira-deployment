server {
    listen 80;
    server_name ngpurchase.realdeals.pro;

    access_log /var/log/nginx/eprocurement_access.log;
    error_log /var/log/nginx/eprocurement_error.log;

    # Serve React frontend
    root /var/www/eProcurement/frontend;
    index index.html;

    # API calls proxied to .NET
    location /api/ {
        proxy_pass http://localhost:5000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend - handles React Router
    location / {
        try_files $uri /index.html;
    }
}

server {
    listen 3001 default_server;
    listen [::]:3001 default_server;

    server_name _;

    root /var/www/eProcurement/frontend-2;
    index index.html;

    location /api/ {
        proxy_pass http://localhost:5001/api/;
    }

    location / {
        try_files $uri /index.html;
    }
}
